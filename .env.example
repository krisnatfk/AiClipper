APP_NAME=AutoClip AI
NEXT_PUBLIC_APP_NAME=AutoClip AI

# Database Configuration
DATABASE_URL=file:local.db
DATABASE_AUTH_TOKEN=

# Local Storage
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=./storage/uploads
LOCAL_OUTPUT_DIR=./storage/outputs
LOCAL_TEMP_DIR=./storage/tmp

# AI Analysis
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Transcription
TRANSCRIBE_ENGINE=faster-whisper
WHISPER_MODEL=small
WHISPER_DEVICE=cpu

# Video Processing — Windows PowerShell defaults.
# On Linux/WSL, override these with Linux paths.
FFMPEG_PATH=C:/Users/USER/AppData/Local/Microsoft/WinGet/Links/ffmpeg.exe
FFPROBE_PATH=C:/Users/USER/AppData/Local/Microsoft/WinGet/Links/ffprobe.exe
PYTHON_PATH=C:/Users/USER/AppData/Local/Programs/Python/Python312/python.exe

# Queue
QUEUE_DRIVER=database
REDIS_URL=

# Upload / Render Defaults
MAX_UPLOAD_SIZE_MB=1024
MAX_VIDEO_DURATION_MINUTES=60
DEFAULT_CLIP_COUNT=5
DEFAULT_CLIP_MIN_SECONDS=30
DEFAULT_CLIP_MAX_SECONDS=90

# Cloudflare R2 (production storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Legacy only. Not used by the default self-processing flow.
OPUS_API_KEY=
OPUS_API_BASE_URL=
OPUS_ORG_ID=
